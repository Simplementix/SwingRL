# config/swingrl.prod.yaml.example — Production reference values (annotated)
# Copy to swingrl.prod.yaml on homelab. NEVER commit real credentials.
# In Docker: override sensitive fields via .env (chmod 600) using SWINGRL_ prefix.
# Example .env line: SWINGRL_TRADING_MODE=live

trading_mode: live  # OVERRIDE via: SWINGRL_TRADING_MODE=live

equity:
  symbols: [SPY, QQQ, VTI, XLV, XLI, XLE, XLF, XLK]
  max_position_size: 0.25       # conservative for Phase 1 live trading
  max_drawdown_pct: 0.10        # 10% DD halts equity — do not raise until Sharpe > 0.7 sustained
  daily_loss_limit_pct: 0.02    # 2% daily loss limit

crypto:
  symbols: [BTCUSDT, ETHUSDT]
  max_position_size: 0.50
  max_drawdown_pct: 0.12        # 12% DD halts crypto
  daily_loss_limit_pct: 0.03    # 3% daily loss limit
  min_order_usd: 10.0           # Binance.US $10 floor — never lower this

capital:
  equity_usd: 400.0             # update when depositing additional capital
  crypto_usd: 47.0              # update when transferring from Coinbase to Binance.US

paths:
  data_dir: /app/data/          # absolute paths in production Docker container
  db_dir: /app/db/
  models_dir: /app/models/
  logs_dir: /app/logs/

logging:
  level: INFO
  json_logs: true               # JSON to stdout — collected by Docker log aggregation
  # Override: SWINGRL_LOGGING__JSON_LOGS=true

system:
  duckdb_path: /app/data/db/market_data.ddb   # DuckDB: market data analytics
  sqlite_path: /app/data/db/trading_ops.db    # SQLite: trading operations

alerting:
  alert_cooldown_minutes: 30               # minimum minutes between repeat alerts
  consecutive_failures_before_alert: 3     # failures before triggering alert

features:
  equity_zscore_window: 252        # rolling z-score window for equity (trading days)
  crypto_zscore_window: 360        # rolling z-score window for crypto (4H bars ~60 days)
  equity_hmm_window: 1260          # HMM fitting window for equity (5 years daily)
  crypto_hmm_window: 2000          # HMM fitting window for crypto (4H bars ~1 year)
  hmm_n_iter: 200                  # max EM iterations per HMM fit
  hmm_n_inits: 5                   # random initializations, best log-likelihood wins
  hmm_ridge: 0.000001             # ridge regularization for HMM covariance stability
  correlation_threshold: 0.85      # Pearson r threshold for feature pruning
  zscore_epsilon: 0.00000001      # floor for rolling std to prevent division by zero
  equity_turbulence_warmup: 252    # expanding lookback warmup for equity turbulence
  crypto_turbulence_window: 1080   # rolling window for crypto turbulence (4H bars)
  crypto_turbulence_warmup: 360    # crypto turbulence minimum warmup bars
