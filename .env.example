# SwingRL Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git — it is gitignored.

# Alpaca Markets (equities) — https://alpaca.markets/
ALPACA_API_KEY=""
ALPACA_SECRET_KEY=""

# Binance.US (crypto) — https://www.binance.us/
BINANCE_API_KEY=""
BINANCE_SECRET_KEY=""

# Discord Webhook for alerts — https://discord.com/developers/docs/resources/webhook
DISCORD_WEBHOOK_URL=""

# FRED API (Federal Reserve economic data) — https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=""

# Memory agent service — generate with: openssl rand -hex 16
MEMORY_API_KEY="change-me-to-random-hex"  # pragma: allowlist secret

# Memory agent config overrides (Pydantic env var style: SWINGRL_ prefix + double-underscore nesting)
SWINGRL_MEMORY_AGENT__API_KEY=""  # Must match MEMORY_API_KEY above
SWINGRL_MEMORY_AGENT__ENABLED="false"  # Set "true" to enable memory agent
SWINGRL_MEMORY_AGENT__META_TRAINING="false"  # Set "true" for LLM-guided hyperparameter tuning

# NVIDIA NIM API (consolidation LLM) — https://build.nvidia.com/
NVIDIA_API_KEY=""

# PostgreSQL (primary database — replaces DuckDB + SQLite)
# Uses existing pg16 container on br0 network
DATABASE_URL="postgresql://swingrl:changeme@pg16:5432/swingrl"  # pragma: allowlist secret

# LLM providers for memory agent (epoch advice, HP tuning, consolidation)
# Cerebras (primary epoch advice) — https://cloud.cerebras.ai/
CEREBRAS_API_KEY=""
# Groq (epoch advice fallback) — https://console.groq.com/
GROQ_API_KEY=""
# Gemini (HP tuning) — https://aistudio.google.com/apikey
GEMINI_API_KEY=""
# Mistral (consolidation) — https://console.mistral.ai/
MISTRAL_API_KEY=""
# OpenRouter (fallback for all LLM calls) — https://openrouter.ai/
OPENROUTER_API_KEY=""
